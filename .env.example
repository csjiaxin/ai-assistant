# ════════════════════════════════════════════════════════════════════
# Slack AI Support Agent — Environment Configuration
# ✅ ALL DEFAULTS USE FREE, LOCAL MODELS — no API keys required!
# Copy this file to .env and fill in only your Slack credentials.
# ════════════════════════════════════════════════════════════════════

# ── Slack App Credentials (required) ────────────────────────────────
# From https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here     # Required for Socket Mode
SLACK_SIGNING_SECRET=your-signing-secret-here

# Comma-separated Slack channel IDs to monitor and ingest
MONITORED_CHANNELS=C04XXXXXXX,C05YYYYYYY

# ════════════════════════════════════════════════════════════════════
# EMBEDDING MODEL — FREE, LOCAL (no API key needed)
# ════════════════════════════════════════════════════════════════════
# Backend: "local" (default) uses sentence-transformers on your CPU/GPU
EMBEDDING_BACKEND=local

# Model shorthand options (downloaded once from HuggingFace, free):
#   minilm    → all-MiniLM-L6-v2       384-dim  ~80MB   fastest
#   bge-small → BAAI/bge-small-en-v1.5 384-dim  ~130MB  best small retrieval
#   bge-base  → BAAI/bge-base-en-v1.5  768-dim  ~440MB  excellent quality
#   mpnet     → all-mpnet-base-v2       768-dim  ~420MB  highest quality
#   e5-small  → intfloat/e5-small-v2   384-dim  ~130MB  multilingual-ready
EMBEDDING_MODEL=minilm

# ════════════════════════════════════════════════════════════════════
# LLM — FREE, LOCAL via Ollama (https://ollama.ai)
# ════════════════════════════════════════════════════════════════════
# Install Ollama, then pull your chosen model:
#   ollama pull llama3.2      # recommended: fast + smart
#   ollama pull mistral       # 7B, excellent for Q&A
#   ollama pull gemma2:2b     # 2B, very fast, lower RAM
#   ollama pull phi3.5        # 3.8B, great for code questions
#   ollama pull qwen2.5:3b    # 3B, multilingual
#   ollama pull deepseek-r1:7b # 7B, strong reasoning

# Shorthand aliases (maps to latest recommended version):
#   llama3      → llama3.2
#   mistral     → mistral
#   gemma2      → gemma2:2b
#   phi3        → phi3.5
#   qwen        → qwen2.5:3b
#   deepseek    → deepseek-r1:7b
LLM_MODEL=llama3

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# LLM generation settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ════════════════════════════════════════════════════════════════════
# OPTIONAL: OpenAI (only if you want cloud models)
# ════════════════════════════════════════════════════════════════════
# Uncomment and fill in to use GPT-4o or OpenAI embeddings:
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o
# EMBEDDING_BACKEND=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ════════════════════════════════════════════════════════════════════
# STORAGE — all local by default
# ════════════════════════════════════════════════════════════════════
# Vector store: chroma (local) | pinecone (cloud) | qdrant (self-hosted)
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=slack_qa

# Database: SQLite (local) — change to PostgreSQL DSN for production
DATABASE_URL=sqlite:///./data/messages.db

# ════════════════════════════════════════════════════════════════════
# CACHE (optional — works fine without Redis)
# ════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ════════════════════════════════════════════════════════════════════
# RETRIEVAL & INGESTION
# ════════════════════════════════════════════════════════════════════
TOP_K=5
MIN_SIMILARITY=0.4
INGESTION_LOOKBACK_DAYS=180
INGESTION_INTERVAL_MINUTES=15
MIN_THREAD_REPLIES=1

# ════════════════════════════════════════════════════════════════════
# AGENT BEHAVIOUR
# ════════════════════════════════════════════════════════════════════
BOT_NAME=SupportBot
SHOW_SOURCES=true
MAX_CONTEXT_CHARS=6000
